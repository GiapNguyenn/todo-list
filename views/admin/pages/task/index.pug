extends ../../layouts/default
include ../../mixins/filter-status
include ../../mixins/search

block main

  h2.mb-4= pageTitle

  .row.mb-3.align-items-center
    .col-md-6
        +search(keyword)
    .col-md-6.text-right
      a.btn.btn-primary(href="/admin/task/create") Thêm Task

  .mb-3
    +filter-status(filterStatus)

  table.table.table-bordered.table-hover
    thead.table-dark
      tr
        th STT
        th Tên công việc
        th Nội dung
        th Số NV
        th Trạng thái
        th Ngày bắt đầu
        th Ngày kết thúc
        th Hành động

    tbody
      each task, index in tasks
        tr
          td= index + 1
          td= task.title
          td= task.description
          td.text-center= task.quantityMember

          td.text-center
            if task.status === "completed"
                span.badge.badge-success Hoàn thành
            else
                span.badge.badge-secondary Chưa hoàn thành

          td= task.startDate.toLocaleDateString("vi-VN")
          td= task.endDate.toLocaleDateString("vi-VN")

          td
            a.btn.btn-info.btn-sm.me-1(href=`/admin/task/detail/${task._id}`) Chi tiết
            a.btn.btn-warning.btn-sm.me-1(href=`/admin/task/edit/${task._id}`) Sửa
            a.btn.btn-danger.btn-sm(href=`/admin/task/delete/${task._id}`) Xóa